{
  "name": "job-app-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "prettier": {
    "singleQuote": true
  },
  "scripts": {
    "build": "pnpm transpile:electron && pnpm build:vite && pnpm updateDB",
    "build:vite": "tsc && vite build",
    "dev": "pnpm updateDB && npm-run-all --parallel dev:react dev:electron",
    "dev:electron": "pnpm transpile:electron && cross-env NODE_ENV=development electron .",
    "dev:react": "vite",
    "dist:linux": "pnpm build && electron-builder --linux --x64",
    "dist:mac": "pnpm build && electron-builder --mac --arm64",
    "dist:win": "pnpm build && electron-builder --win --x64",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:unit": "vitest src",
    "transpile:electron": "tsc --project src/electron/tsconfig.json",
    "updateDB": "pnpm drizzle-kit push",
    "viewDB": "pnpm drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@rookie-rs/api": "0.5.3-beta.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "os-utils": "^0.0.14",
    "puppeteer": "^23.10.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.5.5",
    "@types/os-utils": "^0.0.4",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.7",
    "vitest": "^2.1.1"
  }
}
